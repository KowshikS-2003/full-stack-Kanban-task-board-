# -------------------------------------------------------
# QuickTask — environment variables
#
# Copy this file to .env (git-ignored) and fill in your values.
#   cp .env.example .env
#
# Used by:
#   docker-compose.yml       (local dev — builds from source)
#   docker-compose.prod.yml  (Podman Desktop — pulls from ghcr.io)
# -------------------------------------------------------

# Your GitHub username or organisation name.
# This is the owner of the ghcr.io packages produced by the CD pipeline.
# Example: if your repo is github.com/johndoe/task-manager, set johndoe.
GITHUB_OWNER=your-github-username
